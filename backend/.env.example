# ───── Server ─────
PORT=3001
NODE_ENV=development

# ───── PostgreSQL ─────
DATABASE_URL=postgres://lada:lada@localhost:5432/lada

# ───── TON ─────
TON_NETWORK=testnet                       # testnet | mainnet
TONCENTER_API_KEY=                        # toncenter.com API key (highly recommended — public RPC is heavily throttled)
ESCROW_CONTRACT_ADDRESS=                  # deployed LadaEscrow contract
HOUSE_WALLET_ADDRESS=                     # receives 5% per race
HOUSE_WALLET_MNEMONIC=                    # 24-word seed phrase; signs DeclareWinner txs sent to escrow
LADA_JETTON_MASTER=                       # jetton master address

# ───── Telegram ─────
TELEGRAM_BOT_TOKEN=                       # used to verify Mini App initData + send bot messages
BOT_NOTIFY_URL=http://localhost:3002/notify
TELEGRAM_WEBHOOK_URL=                     # e.g. https://your-backend.com/api/bot  (auto-registers on boot)
BOT_WEBHOOK_SECRET=                       # random string; Telegram sends it as X-Telegram-Bot-Api-Secret-Token

# ───── Indexer ─────
INDEXER_POLL_MS=5000

# ───── Admin ─────
# Shared-secret token required for /api/house/* mutating endpoints.
# Generate with: `openssl rand -hex 32`
ADMIN_TOKEN=

# Set to 1 to bypass Telegram initData verification on /api routes (dev only)
SKIP_TELEGRAM_AUTH=0
