# Backend API base URL
VITE_API_URL=http://localhost:3001

# TON network: "mainnet" or "testnet"
VITE_TON_NETWORK=testnet

# Deployed Lada escrow contract address
VITE_ESCROW_CONTRACT_ADDRESS=

# Lada jetton master address
VITE_LADA_JETTON_MASTER=

# TON Connect manifest URL (must be publicly reachable from Telegram)
VITE_TONCONNECT_MANIFEST_URL=https://example.com/tonconnect-manifest.json
