# ───── Telegram ─────
TELEGRAM_BOT_TOKEN=

# Where the bot opens the Mini App. Must be the same HTTPS URL registered
# with @BotFather as the Mini App. In dev you can use a Telegram-friendly
# tunnel (ngrok, cloudflared, etc.) pointing at the Vite dev server.
MINI_APP_URL=https://your-mini-app.example.com

# ───── Backend API ─────
BACKEND_URL=http://localhost:3001
# Shared admin token (matches backend's ADMIN_TOKEN). Optional — only needed
# if the bot calls admin-gated backend endpoints.
ADMIN_TOKEN=

# ───── Notification webhook ─────
# The backend (or indexer) POSTs to this server when something happens that
# warrants a Telegram message. Keep this port private; nothing else should
# reach it.
NOTIFY_PORT=3002
# Shared secret used to authenticate the backend → bot push. If unset, the
# webhook accepts any caller (only suitable for local dev).
NOTIFY_TOKEN=

# ───── Public lobby feed (optional) ─────
# When set, every new lobby is broadcast here. Use a channel ID (e.g.
# -1001234567890) or a public @channelname. Leave empty to disable.
LOBBIES_CHANNEL_ID=
